# Create via @BotFather
TELEGRAM_BOT_TOKEN=123456789:replace-me

# Get this from bin/get_chat_id.sh
TELEGRAM_CHAT_ID=123456789

# Optional: HTML (default), MarkdownV2, or empty for plain text
TELEGRAM_PARSE_MODE=HTML

# Optional for turn notifications: both | topic | session
TELEGRAM_TURN_ID_MODE=both

# Optional: include full reply body in the same task-complete message
TELEGRAM_FULL_REPLY=true

# Optional reply rendering mode for reply bodies: auto | plain
# auto: convert markdown-like reply text to Telegram HTML (recommended)
TELEGRAM_REPLY_PARSE_MODE=auto

# Optional timezone for displayed timestamps (default: Asia/Seoul)
TELEGRAM_TIMEZONE=Asia/Seoul

# Optional bridge runtime config
TELEGRAM_BRIDGE_TIMEOUT_SECONDS=1800
TELEGRAM_BRIDGE_PLAIN_TEXT_AS_CODEX=false

# Optional watcher event mode: task_complete (recommended) | agent_message (chatty)
TELEGRAM_NOTIFY_EVENT=task_complete

# Optional for task_complete payload from watcher: full | preview
TELEGRAM_TASK_REPLY_MODE=full

# Optional: notify when Codex asks a question (Plan mode / request_user_input)
TELEGRAM_NOTIFY_REQUEST_USER_INPUT=true

# Optional: notify when Codex updates plan steps (update_plan)
TELEGRAM_NOTIFY_PLAN_UPDATES=true

# Optional: notify when assistant emits plan proposal text (for example <proposed_plan>)
TELEGRAM_NOTIFY_ASSISTANT_PLAN_TEXT=true
